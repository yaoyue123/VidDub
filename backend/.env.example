# SiliconFlow API Credentials
# Get your key at: https://cloud.siliconflow.cn/account/ak
SILICONFLOW_API_KEY=

# SiliconFlow Base URL (optional, only change for proxy/self-hosted)
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# Whisper (local STT) — model size: tiny/base/small/medium
WHISPER_MODEL=tiny
WHISPER_LANGUAGE=en

# Storage
DOWNLOADS_DIR=./downloads
DATABASE_URL=sqlite+aiosqlite:///./data/you2bili.db

# Network (optional, for proxy)
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
